# ============================================
# CognitiveHunt — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control!

# OpenAI API Key (required for chatbot + MITRE mapping)
OPENAI_API_KEY=sk-your-openai-key-here

# VirusTotal API Key (free tier: 4 req/min, 500 req/day)
# Get yours at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-virustotal-key-here

# Shodan API Key (for IP enrichment)
# Get yours at: https://account.shodan.io/register
SHODAN_API_KEY=your-shodan-key-here

# AbuseIPDB API Key (for IP abuse reports)
# Get yours at: https://www.abuseipdb.com/account/plans
ABUSEIPDB_API_KEY=your-abuseipdb-key-here

# GreyNoise API Key (for IP noise vs targeted classification)
# Get yours at: https://www.greynoise.io/plans (Community tier is free)
GREYNOISE_API_KEY=your-greynoise-key-here

# WhoisXML API Key (for domain registration / WHOIS lookups)
# Get yours at: https://whois.whoisxmlapi.com/ (500 free queries/month)
WHOISXML_API_KEY=your-whoisxml-key-here

# URLhaus and MalwareBazaar (abuse.ch) — No API keys needed (free)

# Redis (optional — for production caching)
# REDIS_URL=redis://localhost:6379/0
